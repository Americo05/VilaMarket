@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Email Confirmado";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5 text-center">

                    @if (Model.StatusMessage.Contains("Erro"))
                    {
                        <div class="mb-4">
                            <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
                        </div>
                        <h2 class="fw-bold mb-3 text-danger">Ups! Algo correu mal.</h2>
                        <p class="text-muted lead mb-4">@Model.StatusMessage</p>
                    }
                    else
                    {
                        <div class="mb-4">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                        </div>

                        <h2 class="fw-bold mb-3">Conta Ativada!</h2>
                        <p class="text-muted lead mb-4">
                            O teu email foi verificado com sucesso e a tua sessão foi iniciada automaticamente.
                        </p>

                        <div class="d-grid gap-2 col-8 mx-auto">
                            <a href="/" class="btn btn-primary btn-lg fw-bold">
                                Ir para a Página Inicial
                            </a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>