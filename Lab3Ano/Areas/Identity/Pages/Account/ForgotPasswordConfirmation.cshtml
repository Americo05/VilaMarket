@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Confirmação de Recuperação";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5 text-center">

                    <div class="mb-4">
                        <i class="bi bi-envelope-exclamation-fill text-warning" style="font-size: 4rem;"></i>
                    </div>

                    <h2 class="fw-bold mb-3">Verifica o teu Email</h2>

                    @if (!string.IsNullOrEmpty(Model.StatusMessage))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @Model.StatusMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <p class="text-muted lead mb-4">
                        Se existir uma conta associada a <strong>@Model.Email</strong>, enviámos instruções para recuperar a palavra-passe.
                    </p>

                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <form method="post">
                            <input type="hidden" name="email" value="@Model.Email" />

                            <div class="d-grid gap-2 col-8 mx-auto">
                                <button type="submit" id="resendSubmit" class="btn btn-outline-primary fw-bold" disabled>
                                    <i class="bi bi-send"></i> Reenviar Email
                                </button>
                            </div>
                            <p class="mt-2 small text-muted" id="timerText">Podes reenviar em 60s</p>
                        </form>
                    }
                    else
                    {
                        <p class="small text-muted">Dica: Verifica a pasta de Spam.</p>
                    }

                    <hr class="my-4">

                    <a href="./Login" class="btn btn-link text-decoration-none text-muted">
                        <i class="bi bi-arrow-left"></i> Voltar ao Login
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('resendSubmit');
            var txt = document.getElementById('timerText');

            if (!btn) return;

            var timeLeft = 60;
            btn.disabled = true;

            var timerId = setInterval(function () {
                timeLeft--;

                if (timeLeft > 0) {
                    btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Aguarda...';
                    txt.innerText = 'Podes reenviar em ' + timeLeft + 's';
                } else {
                    clearInterval(timerId);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-send"></i> Reenviar Email';
                    btn.classList.remove('btn-outline-primary');
                    btn.classList.add('btn-primary');
                    txt.innerText = 'Se não recebeste, tenta novamente.';
                }
            }, 1000);
        });
    </script>
}