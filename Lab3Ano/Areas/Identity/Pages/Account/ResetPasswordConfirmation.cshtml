@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Alterada";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5 text-center">

                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                    </div>

                    <h2 class="fw-bold mb-3">Sucesso!</h2>
                    <p class="text-muted lead mb-4">
                        A tua palavra-passe foi atualizada com sucesso. Já podes entrar na tua conta com a nova senha.
                    </p>

                    <div class="d-grid gap-2 col-8 mx-auto">
                        <a asp-page="./Login" class="btn btn-primary btn-lg fw-bold">
                            Ir para o Login
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>