@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Nova Password";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5">

                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="bi bi-key-fill text-primary" style="font-size: 3rem;"></i>
                        </div>
                        <h2 class="fw-bold">Nova Palavra-passe</h2>
                        <p class="text-muted">Define a tua nova segurança.</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3" role="alert"></div>

                        <input asp-for="Input.Code" type="hidden" />
                        <input asp-for="Input.Email" type="hidden" />

                        <div class="form-floating mb-3">
                            <input value="@Model.Input.Email" class="form-control bg-light" disabled placeholder="Email" />
                            <label>Email da Conta</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Nova Pass" />
                            <label asp-for="Input.Password">Nova Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirmar" />
                            <label asp-for="Input.ConfirmPassword">Confirmar Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">Redefinir Password</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}