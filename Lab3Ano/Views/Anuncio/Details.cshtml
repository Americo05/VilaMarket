@model Lab3Ano.Models.Entidades.Anuncio

<style>
    #chatFloatingWindow {
        position: fixed;
        bottom: 0;
        right: 20px;
        width: 360px;
        height: 500px;
        background-color: white;
        z-index: 9999;
        box-shadow: 0 5px 25px rgba(0,0,0,0.2);
        border-top-left-radius: 15px;
        border-top-right-radius: 15px;
        display: none;
        overflow: hidden;
        border: 1px solid #dee2e6;
        flex-direction: column;
    }

        #chatFloatingWindow.show {
            display: flex !important;
            animation: slideUp 0.3s ease-out;
        }

    #chatFloatingBody .card-header {
        display: none !important;
    }

    #chatFloatingBody .card {
        border: none !important;
        box-shadow: none !important;
        height: 100% !important;
    }

    @@keyframes slideUp {
        from {
            transform: translateY(100%);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
</style>

@{
    var marca = Model.IdCarroNavigation?.IdModeloNavigation?.IdMarcaNavigation?.Nome ?? "Marca";
    var modelo = Model.IdCarroNavigation?.IdModeloNavigation?.Nome ?? "Modelo";
    var tituloCompleto = $"{marca} {modelo}";
    ViewData["Title"] = tituloCompleto;
}

<div class="container py-5">

    <div class="mb-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Voltar à Lista
        </a>
    </div>

    <div class="row g-4">

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm mb-4 overflow-hidden bg-light">
                <div class="d-flex align-items-center p-3 border-bottom bg-white">
                    <button class="btn btn-outline-danger rounded-pill px-4 me-3 btn-favorite-details"
                            data-car-id="@Model.Id" style="transition: all 0.3s;">
                        @if (ViewBag.IsFavorito == true)
                        {
                            <i class="bi bi-heart-fill me-2 icon-heart"></i>
                        }
                        else
                        {
                            <i class="bi bi-heart me-2 icon-heart"></i>
                        }
                        <span class="fw-bold">Favorito</span>
                    </button>

                    <div class="text-muted small">
                        <i class="bi bi-people-fill"></i>
                        <span id="contadorLikes" class="fw-bold text-dark">@ViewBag.TotalFavoritos</span> Pessoas Gostaram
                    </div>
                </div>

                @if (Model.Imagems != null && Model.Imagems.Count > 0)
                {
                    <div id="carouselDetalhes" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-indicators">
                            @for (int i = 0; i < Model.Imagems.Count; i++)
                            {
                                <button type="button" data-bs-target="#carouselDetalhes" data-bs-slide-to="@i"
                                        class="@(i == 0 ? "active" : "")" aria-current="true"></button>
                            }
                        </div>
                        <div class="carousel-inner" style="height: 500px; background-color: #000;">
                            @{
                                int index = 0;
                            }
                            @foreach (var imagem in Model.Imagems)
                            {
                                <div class="carousel-item h-100 @(index == 0 ? "active" : "")">
                                    <img src="/imagens/@imagem.Url" class="d-block w-100 h-100"
                                         style="object-fit: contain;" alt="Foto do Carro">
                                </div>
                                index++;
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselDetalhes" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselDetalhes" data-bs-slide="next">
                            <span class="carousel-control-next-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                        </button>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center" style="height: 400px;">
                        <div class="text-center text-muted">
                            <i class="bi bi-camera-fill fs-1"></i> <p>Sem fotos</p>
                        </div>
                    </div>
                }
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2">Características</h5>
                <div class="row g-2 text-center">
                    <div class="col-6 col-md-2">
                        <div class="p-2 border rounded bg-light h-100">
                            <i class="bi bi-tag-fill text-primary fs-5"></i>
                            <div class="small text-muted mt-1" style="font-size: 0.8rem;">Categoria</div>
                            <div class="fw-bold text-dark small">@Model.IdCarroNavigation?.IdCategoriaNavigation?.Nome</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="p-2 border rounded bg-light h-100">
                            <i class="bi bi-fuel-pump text-primary fs-5"></i>
                            <div class="small text-muted mt-1" style="font-size: 0.8rem;">Combustível</div>
                            <div class="fw-bold text-dark small">@Model.IdCarroNavigation?.IdCombustivelNavigation?.Tipo</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="p-2 border rounded bg-light h-100">
                            <i class="bi bi-speedometer2 text-primary fs-5"></i>
                            <div class="small text-muted mt-1" style="font-size: 0.8rem;">Quilómetros</div>
                            <div class="fw-bold text-dark small">@(Model.IdCarroNavigation?.Quilometragem.ToString("N0")) km</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="p-2 border rounded bg-light h-100">
                            <i class="bi bi-gear-wide-connected text-primary fs-5"></i>
                            <div class="small text-muted mt-1" style="font-size: 0.8rem;">Caixa</div>
                            <div class="fw-bold text-dark small">@Model.IdCarroNavigation?.Caixa</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="p-2 border rounded bg-light h-100">
                            <i class="bi bi-lightning-fill text-primary fs-5"></i>
                            <div class="small text-muted mt-1" style="font-size: 0.8rem;">Potência</div>
                            <div class="fw-bold text-dark small">@(Model.IdCarroNavigation?.Potencia) CV</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="p-2 border rounded bg-light h-100">
                            <i class="bi bi-boxes text-primary fs-5"></i>
                            <div class="small text-muted mt-1" style="font-size: 0.8rem;">Cilindrada</div>
                            <div class="fw-bold text-dark small">@(Model.IdCarroNavigation?.Cilindrada) cm³</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2">Descrição</h5>
                <p class="text-muted" style="white-space: pre-line;">@Model.Descricao</p>
                <div class="text-muted small mt-3">
                    <i class="bi bi-geo-alt-fill"></i> Localização: <strong>@Model.IdCarroNavigation?.Localizacao</strong>
                </div>
            </div>

        </div>

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h4 class="text-secondary">@tituloCompleto</h4>
                <h1 class="display-5 fw-bold text-primary mb-2">
                    @(Model.IdCarroNavigation?.Preco.ToString("N0") ?? "N/A") €
                </h1>
                <div class="mb-3">
                    <span class="badge bg-dark fs-6">@Model.IdCarroNavigation?.Ano</span>
                </div>

                @if (Model.Estado == "Reservado")
                {
                    <div class="alert alert-warning text-center fw-bold">RESERVADO</div>
                }
                else if (Model.Estado == "Vendido")
                {
                    <div class="alert alert-danger text-center fw-bold">VENDIDO</div>
                }
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold border-bottom pb-3 mb-3">Vendedor</h5>
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-person-fill fs-4 text-secondary"></i>
                    </div>
                    <div>
                        <div class="fw-bold">
                            <a asp-controller="Perfil" asp-action="Ver"
                               asp-route-id="@Model.IdVendedor" asp-route-tipo="Vendedor"
                               class="text-decoration-none text-dark">
                                @(Model.IdVendedorNavigation?.Nome ?? "Particular")
                            </a>
                        </div>
                        <div class="small text-muted">@Model.IdVendedorNavigation?.Localidade</div>
                        <a asp-controller="Perfil" asp-action="Ver"
                           asp-route-id="@Model.IdVendedor" asp-route-tipo="Vendedor"
                           class="small text-primary text-decoration-none">Ver outros anúncios &rarr;</a>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <a href="tel:@Model.IdVendedorNavigation?.Contactos" class="btn btn-outline-dark">
                        <i class="bi bi-telephone-fill me-2"></i> @(Model.IdVendedorNavigation?.Contactos ?? "Ver Contacto")
                    </a>
                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (Model.IdVendedorNavigation.UserId != ViewBag.CurrentUserId)
                        {
                            <button onclick="abrirChatPopup('@Model.IdVendedorNavigation.UserId', @Model.Id)"
                                    class="btn btn-primary fw-bold w-100">
                                <i class="bi bi-chat-dots-fill"></i>
                                <span>Contactar Vendedor</span>
                            </button>
                        }
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg fw-bold w-100">
                            Faz Login para contactar
                        </a>
                    }
                </div>
            </div>

            @if (User.Identity.IsAuthenticated && Model.IdVendedorNavigation.UserId != ViewBag.CurrentUserId)
            {
                <div class="card shadow-sm border-0 bg-light mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3"><i class="bi bi-cart3"></i> Tens interesse?</h5>

                        @if (Model.Estado == "Ativo")
                        {
                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalVisita">
                                    <i class="bi bi-calendar-event"></i> Agendar Visita / Test-Drive
                                </button>

                                <div class="d-flex gap-2">
                                    <form asp-controller="Negocios" asp-action="Reservar" method="post" class="flex-fill">
                                        <input type="hidden" name="anuncioId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-warning w-100 fw-bold"
                                                onclick="return confirm('A reserva bloqueia o carro por 3 dias. Confirmas?')">
                                            <i class="bi bi-bookmark-star"></i> Reservar
                                        </button>
                                    </form>

                                    <a asp-controller="Anuncio" asp-action="Checkout" asp-route-id="@Model.Id"
                                       class="btn btn-success w-100 fw-bold flex-fill d-flex align-items-center justify-content-center">
                                        <i class="bi bi-bag-check-fill me-2"></i> Comprar
                                    </a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-secondary text-center m-0">
                                <i class="bi bi-info-circle"></i> Negócio indisponível (Estado: @Model.Estado).
                            </div>
                        }
                    </div>
                </div>
            }

            @if (ViewBag.IsDono == true)
            {
                <div class="mt-3 pt-3 border-top">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning w-100 fw-bold">
                        <i class="bi bi-pencil-square"></i> Editar Anúncio
                    </a>
                </div>
            }

            <div id="chatFloatingWindow">
                <div class="d-flex justify-content-between align-items-center bg-primary text-white p-3">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-chat-dots-fill me-2"></i>
                        <span class="fw-bold" id="chatFloatingTitle">Vendedor</span>
                    </div>
                    <button onclick="fecharChat()" class="btn btn-sm btn-link text-white text-decoration-none p-0">
                        <i class="bi bi-x-lg fs-5"></i>
                    </button>
                </div>

                <div id="chatFloatingBody" class="bg-light position-relative flex-grow-1" style="overflow: hidden;">
                    <div class="d-flex justify-content-center align-items-center h-75">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalVisita" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="Negocios" asp-action="AgendarVisita" method="post">
                <input type="hidden" name="anuncioId" value="@Model.Id" />

                <div class="modal-header">
                    <h5 class="modal-title">📅 Agendar Visita</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Data e Hora Preferida</label>
                        <input type="datetime-local" name="dataHora" class="form-control" required>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Enviar Pedido</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var chatInterval = null;
        var chatUrlBase = "";

        $(document).ready(function () {
            $('.btn-favorite-details').click(function () {
                var btn = $(this);
                var icon = btn.find('.icon-heart');
                var counter = $('#contadorLikes');
                var carId = btn.data('car-id');

                btn.prop('disabled', true);

                $.post('/Home/ToggleFavorite', { carId: carId })
                    .done(function (data) {
                        if (data.success) {
                            if (data.isLiked) {
                                icon.removeClass('bi-heart').addClass('bi-heart-fill');
                                btn.removeClass('btn-outline-danger').addClass('btn-danger text-white');
                            } else {
                                icon.removeClass('bi-heart-fill').addClass('bi-heart');
                                btn.removeClass('btn-danger text-white').addClass('btn-outline-danger');
                            }
                            counter.text(data.newCount);
                        }
                    })
                    .always(function() { btn.prop('disabled', false); });
            });
        });

        function abrirChatPopup(userId, anuncioId) {
            var chatWindow = document.getElementById('chatFloatingWindow');
            var chatBody = document.getElementById('chatFloatingBody');

            chatWindow.classList.add('show');
            chatUrlBase = `/Mensagens/ChatPartial?outroUserId=${userId}&anuncioId=${anuncioId}`;

            carregarChat();
        }

        function carregarChat() {
            var chatBody = document.getElementById('chatFloatingBody');
            var url = chatUrlBase + "&v=" + new Date().getTime();

            fetch(url)
                .then(r => r.text())
                .then(html => {
                    chatBody.innerHTML = html;


                    var parser = new DOMParser();
                    var doc = parser.parseFromString(html, 'text/html');
                    var headerInvisivel = doc.querySelector('.card-header h6');

                    if(headerInvisivel) {
                         document.getElementById('chatFloatingTitle').textContent = headerInvisivel.textContent.trim();
                    }

                    scrollParaFundo();

                    if (chatInterval) clearInterval(chatInterval);
                    chatInterval = setInterval(atualizarMensagensEmBackground, 2500);
                })
                .catch(err => console.error("Erro ao abrir chat:", err));
        }

        function atualizarMensagensEmBackground() {
            if (!document.getElementById('chatFloatingWindow').classList.contains('show')) {
                clearInterval(chatInterval);
                return;
            }

            var url = chatUrlBase + "&v=" + new Date().getTime();

            fetch(url)
                .then(r => r.text())
                .then(html => {

                    if(!html || html.length < 50) return;

                    var parser = new DOMParser();
                    var doc = parser.parseFromString(html, 'text/html');


                    var novaLista = doc.getElementById('chatBox');
                    if (!novaLista) novaLista = doc.querySelector('.card-body');

                    var chatBoxAtual = document.getElementById('chatBox') || document.querySelector('#chatFloatingBody .card-body');

                    if (novaLista && chatBoxAtual) {
                        if (chatBoxAtual.innerHTML.trim() !== novaLista.innerHTML.trim()) {
                            chatBoxAtual.innerHTML = novaLista.innerHTML;
                            scrollParaFundo();
                        }
                    }
                })
                .catch(e => console.log("A aguardar..."));
        }

        function scrollParaFundo() {
            var chatBox = document.getElementById("chatBox") || document.querySelector('#chatFloatingBody .card-body');
            if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
        }

        function fecharChat() {
            document.getElementById('chatFloatingWindow').classList.remove('show');
            if (chatInterval) clearInterval(chatInterval);
        }

        function enviarMensagemInterna(e) {
            e.preventDefault();
            var inputTexto = document.getElementById("txtMensagemInterno");
            var inputDest = document.getElementById("destinatarioIdInterno");
            var inputAnuncio = document.getElementById("anuncioIdInterno");

            if (!inputTexto || !inputTexto.value.trim()) return;

            var dados = new FormData();
            dados.append("destinatarioId", inputDest.value);
            dados.append("conteudo", inputTexto.value);
            if (inputAnuncio) dados.append("anuncioId", inputAnuncio.value);

            inputTexto.disabled = true;

            fetch('/Mensagens/Enviar', { method: 'POST', body: dados })
            .then(r => r.json())
            .then(data => {
                inputTexto.disabled = false;
                inputTexto.value = "";
                inputTexto.focus();

                if (data.success) {
                    setTimeout(atualizarMensagensEmBackground, 100);
                }
            })
            .catch(err => {
                inputTexto.disabled = false;
                alert("Erro ao enviar.");
            });
        }
    </script>
}