@{
    ViewData["Title"] = "Pedido Recebido";
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm p-5 border-0" style="max-width: 600px; margin: 0 auto;">
        <h1 class="text-success display-1"><i class="bi bi-check-circle-fill"></i></h1>
        <h2 class="fw-bold mt-3">Pedido Enviado!</h2>
        <p class="lead text-muted mt-3">
            O teu pedido foi registado. Aguarda que um administrador valide os teus dados.
        </p>
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Voltar à Loja</a>
        </div>
    </div>
</div>