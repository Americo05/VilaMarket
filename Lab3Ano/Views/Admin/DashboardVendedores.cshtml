@model IEnumerable<Lab3Ano.Models.Entidades.Vendedor>

@{
    ViewData["Title"] = "Pedidos Pendentes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-person-check-fill text-warning"></i> Aprovar Vendedores</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-success text-center p-5 shadow-sm">
            <h3><i class="bi bi-check-circle"></i> Tudo tratado!</h3>
            <p>Não existem novos pedidos de vendedor para aprovar.</p>
            <a asp-action="GerirUtilizadores" class="btn btn-primary mt-3">Ver Todos os Utilizadores</a>
        </div>
    }
    else
    {
        <div class="card shadow border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="ps-4">Empresa / Vendedor</th>
                            <th>Dados Fiscais</th>
                            <th>Morada Completa</th>
                            <th>Contacto</th>
                            <th class="text-end pe-4">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold fs-5">@item.Nome</div>

                                    @if (!string.IsNullOrEmpty(item.TipoEmp))
                                    {
                                        <span class="badge bg-info text-dark mb-1">@item.TipoEmp</span>
                                    }
                                    <div class="small text-muted" style="font-size: 0.75rem;">
                                        ID: @item.UserId
                                    </div>
                                </td>

                                <td>
                                    <div class="fw-bold"><i class="bi bi-card-heading"></i> @item.Nif</div>
                                    <div class="small text-muted">
                                        <i class="bi bi-globe"></i> @(item.Pais ?? "Não definido")
                                    </div>
                                </td>

                                <td>
                                    <div class="text-break" style="max-width: 250px;">
                                        @item.Morada
                                    </div>
                                    <div class="small text-muted fw-bold">
                                        @item.CodPostal @item.Localidade
                                    </div>
                                </td>

                                <td>
                                    <i class="bi bi-telephone-fill text-secondary"></i> @item.Contactos
                                </td>

                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <form asp-action="AprovarVendedor" asp-route-id="@item.Id" method="post">
                                            <button type="submit" class="btn btn-success btn-sm fw-bold px-3 shadow-sm">
                                                <i class="bi bi-check-lg"></i> Aprovar
                                            </button>
                                        </form>

                                        <form asp-action="RejeitarVendedor" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Tens a certeza que queres rejeitar e apagar este pedido?');">
                                            <button type="submit" class="btn btn-danger btn-sm shadow-sm" title="Rejeitar Pedido">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>