@model IEnumerable<Lab3Ano.Models.UtilizadorAdminViewModel>

@{
    ViewData["Title"] = "Gestão de Utilizadores";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Gestão de Utilizadores</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>

    <div class="card mb-4 bg-light border-0">
        <div class="card-body p-3">
            <form method="get" asp-action="GerirUtilizadores" class="row g-3 align-items-center" onsubmit="return false;">

                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchInput" name="pesquisa"
                               value="@ViewData["PesquisaAtual"]"
                               placeholder="Começa a escrever para filtrar...">
                    </div>
                </div>

                <div class="col-md-4">
                    <select class="form-select" name="filtroTipo" onchange="this.form.submit()">
                        <option value="Todos">Todos os Tipos</option>

                        @if (ViewData["FiltroTipoAtual"] as string == "Comprador")
                        {
                            <option value="Comprador" selected>Apenas Compradores</option>
                        }
                        else
                        {
                            <option value="Comprador">Apenas Compradores</option>
                        }

                        @if (ViewData["FiltroTipoAtual"] as string == "Vendedor")
                        {
                            <option value="Vendedor" selected>Apenas Vendedores</option>
                        }
                        else
                        {
                            <option value="Vendedor">Apenas Vendedores</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>
                                <a asp-action="GerirUtilizadores"
                                   asp-route-sortOrder="@ViewData["TipoSortParm"]"
                                   asp-route-pesquisa="@ViewData["PesquisaAtual"]"
                                   asp-route-filtroTipo="@ViewData["FiltroTipoAtual"]"
                                   class="text-dark text-decoration-none">
                                    Tipo <i class="bi bi-arrow-down-up small text-muted"></i>
                                </a>
                            </th>

                            <th>
                                <a asp-action="GerirUtilizadores"
                                   asp-route-sortOrder="@ViewData["NomeSortParm"]"
                                   asp-route-pesquisa="@ViewData["PesquisaAtual"]"
                                   asp-route-filtroTipo="@ViewData["FiltroTipoAtual"]"
                                   class="text-dark text-decoration-none">
                                    Nome <i class="bi bi-arrow-down-up small text-muted"></i>
                                </a>
                            </th>

                            <th>
                                <a asp-action="GerirUtilizadores"
                                   asp-route-sortOrder="@ViewData["EmailSortParm"]"
                                   asp-route-pesquisa="@ViewData["PesquisaAtual"]"
                                   asp-route-filtroTipo="@ViewData["FiltroTipoAtual"]"
                                   class="text-dark text-decoration-none">
                                    Email <i class="bi bi-arrow-down-up small text-muted"></i>
                                </a>
                            </th>

                            <th>
                                <a asp-action="GerirUtilizadores"
                                   asp-route-sortOrder="@ViewData["EstadoSortParm"]"
                                   asp-route-pesquisa="@ViewData["PesquisaAtual"]"
                                   asp-route-filtroTipo="@ViewData["FiltroTipoAtual"]"
                                   class="text-dark text-decoration-none">
                                    Estado <i class="bi bi-arrow-down-up small text-muted"></i>
                                </a>
                            </th>

                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="tabelaCorpo">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (item.Tipo == "Admin")
                                    {
                                        <span class="badge bg-danger">Administrador</span>
                                    }
                                    else if (item.Tipo == "Comprador")
                                    {
                                        <span class="badge bg-info text-dark">Comprador</span>
                                    }
                                    else
                                    {
                                        @if (item.IsAprovado == true)
                                        {
                                            <span class="badge bg-warning text-dark">Vendedor</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary">Candidato</span>
                                        }
                                    }
                                </td>

                                <td>
                                    <a asp-controller="Perfil" asp-action="Ver"
                                       asp-route-id="@item.Id"
                                       asp-route-tipo="@item.Tipo"
                                       class="fw-bold text-dark text-decoration-none hover-primary" target="_blank">

                                        @item.Nome

                                        @if (item.Tipo == "Vendedor")
                                        {
                                            <i class="bi bi-shop ms-1 text-primary" title="Perfil de Vendedor"></i>
                                        }
                                        else if (item.Tipo == "Admin")
                                        {
                                            <i class="bi bi-shield-lock-fill ms-1 text-danger" title="Administrador"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-person ms-1 text-secondary" title="Perfil de Utilizador"></i>
                                        }
                                    </a>
                                </td>

                                <td>@item.Email</td>

                                <td>
                                    @if (item.IsBloqueado)
                                    {
                                        <span class="badge bg-danger" title="@item.MotivoBloqueio">Bloqueado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Ativo</span>
                                        @if (item.Tipo == "Vendedor" && item.IsAprovado == false)
                                        {
                                            <span class="badge bg-secondary ms-1">Não Aprovado</span>
                                        }
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">

                                        @if (item.Tipo == "Vendedor" && item.IsAprovado != true)
                                        {
                                            <span class="badge bg-warning text-dark d-flex align-items-center border border-dark" title="Vai à Dashboard de Aprovação para aceitar este pedido">
                                                <i class="bi bi-hourglass-split me-1"></i> Pendente
                                            </span>
                                        }

                                        <button type="button"
                                                class="btn btn-sm @(item.IsBloqueado ? "btn-dark" : "btn-danger")"
                                                data-bs-toggle="modal"
                                                data-bs-target="#bloqueioModal"
                                                data-id="@item.Id"
                                                data-tipo="@item.Tipo"
                                                data-motivo="@item.MotivoBloqueio"
                                                data-acao="@(item.IsBloqueado ? "Desbloquear" : "Bloquear")">

                                            @if (item.IsBloqueado)
                                            {
                                                <span><i class="bi bi-unlock-fill"></i> Desbloquear</span>
                                            }
                                            else
                                            {
                                                <span><i class="bi bi-lock-fill"></i> Bloquear</span>
                                            }
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div id="msgSemResultados" class="text-center p-3 text-muted" style="display: none;">
                    Nenhum utilizador encontrado.
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="bloqueioModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="BloquearDesbloquear" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitulo">Gerir Bloqueio</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="id" id="modalUserId" />
                    <input type="hidden" name="tipo" id="modalUserType" />

                    <p id="modalMsg" class="mb-3">Tem a certeza?</p>

                    <div class="mb-3" id="divMotivoContainer">
                        <label for="motivo" class="form-label fw-bold">Motivo:</label>
                        <textarea class="form-control" name="motivo" id="modalMotivo" rows="3" placeholder="Escreva a razão do bloqueio..."></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="btnConfirmar">Confirmar Ação</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            var valorPesquisa = this.value.toLowerCase();
            var linhas = document.querySelectorAll('#tabelaCorpo tr');
            var msgSemResultados = document.getElementById('msgSemResultados');
            var encontrouAlgum = false;

            linhas.forEach(function(linha) {
                var nome = linha.cells[1].textContent.toLowerCase();
                var email = linha.cells[2].textContent.toLowerCase();

                if (nome.includes(valorPesquisa) || email.includes(valorPesquisa)) {
                    linha.style.display = '';
                    encontrouAlgum = true;
                } else {
                    linha.style.display = 'none';
                }
            });

            if (!encontrouAlgum) {
                msgSemResultados.style.display = 'block';
            } else {
                msgSemResultados.style.display = 'none';
            }
        });

        var bloqueioModal = document.getElementById('bloqueioModal');
        var modalMotivoInput = bloqueioModal.querySelector('#modalMotivo');
        var btnConfirmar = bloqueioModal.querySelector('#btnConfirmar');
        var acaoAtual = "";

        bloqueioModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var tipo = button.getAttribute('data-tipo');
            var motivo = button.getAttribute('data-motivo');
            var acao = button.getAttribute('data-acao');

            acaoAtual = acao;

            var modalTitle = bloqueioModal.querySelector('.modal-title');
            var modalIdInput = bloqueioModal.querySelector('#modalUserId');
            var modalTypeInput = bloqueioModal.querySelector('#modalUserType');
            var modalMsg = bloqueioModal.querySelector('#modalMsg');
            var divMotivo = document.getElementById('divMotivoContainer');

            modalTitle.textContent = acao + ' Utilizador';
            modalIdInput.value = id;
            modalTypeInput.value = tipo;

            if (acao === "Desbloquear") {
                divMotivo.style.display = 'none';
                modalMotivoInput.value = "";
                modalMsg.textContent = "Tem a certeza que deseja remover o bloqueio deste utilizador?";
                btnConfirmar.disabled = false;
            } else {
                divMotivo.style.display = 'block';
                modalMotivoInput.value = motivo ? motivo : '';
                modalMsg.textContent = "Indique o motivo para bloquear este " + tipo + ".";

                if (modalMotivoInput.value.trim() === "") {
                    btnConfirmar.disabled = true;
                } else {
                    btnConfirmar.disabled = false;
                }
            }
        });

        modalMotivoInput.addEventListener('input', function() {
            if (acaoAtual === "Bloquear") {
                if (this.value.trim() === "") {
                    btnConfirmar.disabled = true;
                } else {
                    btnConfirmar.disabled = false;
                }
            }
        });
    </script>
}