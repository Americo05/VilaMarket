@using Lab3Ano.Models
@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Painel de Administração";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Painel de Administração</h2>
        
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card text-white bg-primary h-100 shadow-sm border-0">
                <div class="card-header fw-bold border-0 bg-primary">UTILIZADORES</div>
                <div class="card-body">
                    <h1 class="display-4 fw-bold">@Model.TotalUtilizadores</h1>
                    <p class="card-text opacity-75">
                        <small>@ViewBag.TotalAdmins Admins</small> |
                        <small>@Model.TotalVendedores Vendedores</small> |
                        <small>@Model.TotalCompradores Compradores</small>
                    </p>
                </div>
                <div class="card-footer border-0 bg-primary d-flex justify-content-between align-items-center">
                    <a asp-controller="Admin" asp-action="GerirUtilizadores" class="text-white text-decoration-none small stretched-link">Gerir Utilizadores</a>
                    <i class="bi bi-chevron-right"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success h-100 shadow-sm border-0">
                <div class="card-header fw-bold border-0 bg-success">ANÚNCIOS</div>
                <div class="card-body">
                    <h1 class="display-4 fw-bold">@Model.TotalAnuncios</h1>
                    <p class="card-text opacity-75" style="font-size: 0.9rem;">
                        <small>@ViewBag.AnunciosAtivos Ativos</small> |
                        <small>@ViewBag.AnunciosReservados Res.</small> |
                        <small>@ViewBag.AnunciosVendidos Vend.</small> |
                        <small>@ViewBag.AnunciosRemovidos Rem.</small>
                    </p>
                </div>
                <div class="card-footer border-0 bg-success d-flex justify-content-between align-items-center">
                    <a asp-controller="Admin" asp-action="GerirAnuncios" class="text-white text-decoration-none small stretched-link">Moderar Anúncios</a>
                    <i class="bi bi-chevron-right"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-dark bg-warning h-100 shadow-sm border-0">
                <div class="card-header fw-bold border-0 bg-warning">APROVAÇÕES</div>
                <div class="card-body">
                    @if (ViewBag.PedidosPendentes > 0)
                    {
                        <h1 class="display-4 fw-bold">@ViewBag.PedidosPendentes</h1>
                        <p class="card-text fw-bold text-danger"><i class="bi bi-exclamation-circle-fill"></i> Pedidos Pendentes</p>
                    }
                    else
                    {
                        <h1 class="display-4 fw-bold">0</h1>
                        <p class="card-text text-muted"><i class="bi bi-check-circle-fill"></i> Tudo tratado</p>
                    }
                </div>
                <div class="card-footer border-0 bg-warning d-flex justify-content-between align-items-center">
                    <a asp-controller="Admin" asp-action="DashboardVendedores" class="text-dark text-decoration-none small stretched-link fw-bold">Ver Pedidos</a>
                    <i class="bi bi-chevron-right"></i>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold text-secondary mb-4"><i class="bi bi-bar-chart-line-fill"></i> Métricas da Plataforma</h4>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="bg-light rounded-circle p-3 me-3 text-primary">
                        <i class="bi bi-cash-stack fs-1"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase mb-1">Valor Total em Stock</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.ValorTotalStock.ToString("C0")</h3>
                        <small class="text-success"><i class="bi bi-graph-up-arrow"></i> Valor acumulado de ativos</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="bg-light rounded-circle p-3 me-3 text-info">
                        <i class="bi bi-tags-fill fs-1"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase mb-1">Preço Médio por Veículo</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.PrecoMedio.ToString("C0")</h3>
                        <small class="text-muted">Média geral da plataforma</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white fw-bold py-3">Top 5 Marcas Mais Populares</div>
                <div class="card-body">
                    <canvas id="marcasChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white fw-bold py-3">Distribuição de Combustível</div>
                <div class="card-body d-flex justify-content-center align-items-center">
                    <div style="width: 100%; max-width: 250px;">
                        <canvas id="combustivelChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold py-3">Top Localizações (Onde estão os carros?)</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Cidade</th>
                                    <th>Quantidade de Anúncios</th>
                                    <th>Percentagem (aprox.)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var totalLocais = (int)Model.TotalAnuncios;
                                    var listaLocais = ViewBag.TopLocais as dynamic;
                                }
                                @if (listaLocais != null)
                                {
                                    foreach (var local in listaLocais)
                                    {
                                        int qtd = local.Quantidade;
                                        double percent = totalLocais > 0 ? ((double)qtd / totalLocais) * 100 : 0;
                                        <tr>
                                            <td class="ps-4 fw-bold text-primary">@local.Cidade</td>
                                            <td>@qtd Veículos</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <span class="me-2">@Math.Round(percent, 1)%</span>
                                                    <div class="progress flex-grow-1" style="height: 6px;">
                                                        <div class="progress-bar bg-info" role="progressbar" style="width: @percent%"></div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        var ctxMarcas = document.getElementById('marcasChart').getContext('2d');
        var marcasChart = new Chart(ctxMarcas, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.TopMarcasLabels)),
                datasets: [{
                    label: 'Número de Veículos',
                    data: @Html.Raw(Json.Serialize(ViewBag.TopMarcasData)),
                    backgroundColor: 'rgba(54, 162, 235, 0.6)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1,
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
            }
        });

        var ctxComb = document.getElementById('combustivelChart').getContext('2d');
        var combustivelChart = new Chart(ctxComb, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.CombustivelLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(ViewBag.CombustivelData)),
                    backgroundColor: [
                        '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF'
                    ],
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    });
</script>