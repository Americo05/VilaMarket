@model IEnumerable<Lab3Ano.Models.AnuncioAdminViewModel>

@{
    ViewData["Title"] = "Moderação de Anúncios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Moderação de Anúncios</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>

    <div class="card mb-4 bg-light border-0">
        <div class="card-body p-3">
            <form method="get" asp-action="GerirAnuncios" class="row g-3 align-items-center" onsubmit="return false;">

                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchInput" name="pesquisa"
                               value="@ViewData["PesquisaAtual"]"
                               placeholder="Começa a escrever o título ou vendedor para filtrar...">
                    </div>
                </div>

                <div class="col-md-4">
                    <select class="form-select" name="filtroEstado" onchange="this.form.submit()">
                        <option value="Todos">Todos os Estados</option>
                        <option value="Ativo" selected="@(ViewData["FiltroEstadoAtual"] as string == "Ativo")">Ativos</option>
                        <option value="Reservado" selected="@(ViewData["FiltroEstadoAtual"] as string == "Reservado")">Reservados</option>
                        <option value="Vendido" selected="@(ViewData["FiltroEstadoAtual"] as string == "Vendido")">Vendidos</option>
                        <option value="Pausado" selected="@(ViewData["FiltroEstadoAtual"] as string == "Pausado")">Pausados</option>
                        <option value="Removido" selected="@(ViewData["FiltroEstadoAtual"] as string == "Removido")">Removidos (Lixeira)</option>
                    </select>
                </div>

            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 100px;">Imagem</th>
                        <th>Detalhes</th>
                        <th>Vendedor</th>
                        <th>Estado</th>
                        <th class="text-end" style="min-width: 180px;">Ações</th>
                    </tr>
                </thead>
                <tbody id="tabelaCorpo">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@(item.ImagemCapaUrl.StartsWith("/") ? item.ImagemCapaUrl : "/imagens/" + item.ImagemCapaUrl)"
                                     alt="Foto"
                                     asp-append-version="true"
                                     class="img-thumbnail"
                                     style="width: 80px; height: 60px; object-fit: cover;"
                                     onerror="this.src='https://via.placeholder.com/80x60?text=Sem+Foto';" />
                            </td>

                            <td>
                                <div class="fw-bold">@item.Titulo</div>
                                <div class="text-success small">@item.Preco.ToString("C0")</div>
                                <div class="text-muted small">@item.DataCriacao?.ToShortDateString()</div>
                            </td>

                            <td>
                                <a asp-controller="Perfil"
                                   asp-action="Ver"
                                   asp-route-id="@item.IdVendedor"
                                   asp-route-tipo="Vendedor"
                                   class="fw-bold text-dark text-decoration-none hover-primary" target="_blank">
                                    @item.NomeVendedor <i class="bi bi-box-arrow-up-right small text-muted ms-1" style="font-size: 0.7em;"></i>
                                </a>
                            </td>

                            <td>
                                @if (item.Estado == "Ativo" || item.Estado == "ativo")
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else if (item.Estado == "Reservado" || item.Estado == "reservado")
                                {
                                    <span class="badge bg-info text-dark">Reservado</span>
                                }
                                else if (item.Estado == "Vendido" || item.Estado == "vendido")
                                {
                                    <span class="badge bg-dark">Vendido</span>
                                }
                                else if (item.Estado == "Pausado" || item.Estado == "pausado")
                                {
                                    <span class="badge bg-warning text-dark">Pausado</span>
                                }
                                else if (item.Estado == "Removido" || item.Estado == "removido")
                                {
                                    <span class="badge bg-danger">Removido</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Estado</span>
                                }
                            </td>

                            <td class="text-end">
                                <a asp-controller="Anuncio" asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning text-dark me-1"
                                   title="Editar Anúncio">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <a href="/Anuncio/Details/@item.Id" target="_blank" class="btn btn-sm btn-outline-primary me-1" title="Ver no Site">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (item.Estado != "Removido" && item.Estado != "removido")
                                {
                                    @if (item.Estado == "Ativo" || item.Estado == "ativo" || item.Estado == null)
                                    {
                                        <form asp-action="AtualizarEstadoAnuncio" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="novoEstado" value="Pausado" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning text-dark" title="Pausar">
                                                <i class="bi bi-pause-circle"></i>
                                            </button>
                                        </form>
                                    }

                                    @if (item.Estado == "Pausado" || item.Estado == "pausado")
                                    {
                                        <form asp-action="AtualizarEstadoAnuncio" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="novoEstado" value="Ativo" />
                                            <button type="submit" class="btn btn-sm btn-success" title="Ativar">
                                                <i class="bi bi-play-circle"></i>
                                            </button>
                                        </form>
                                    }

                                    <form asp-action="AtualizarEstadoAnuncio" method="post" class="d-inline ms-1" onsubmit="return confirm('Mover para os Removidos? (Ainda poderá recuperar depois)');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="novoEstado" value="Removido" />
                                        <button type="submit" class="btn btn-sm btn-danger" title="Mover para Removidos">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }

                                @if (item.Estado == "Removido" || item.Estado == "removido")
                                {
                                    <form asp-action="AtualizarEstadoAnuncio" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="novoEstado" value="Ativo" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Restaurar Anúncio">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </form>

                                    <form asp-action="ApagarAnuncioPermanente" method="post" class="d-inline ms-1" onsubmit="return confirm('ATENÇÃO: Isto vai apagar o anúncio da Base de Dados para sempre. Não é reversível. Confirmar?');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-dark" title="Apagar da Base de Dados">
                                            <i class="bi bi-x-circle-fill"></i> Eliminar
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div id="msgSemResultados" class="text-center p-3 text-muted" style="display: none;">
                Nenhum anúncio encontrado.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            var valorPesquisa = this.value.toLowerCase();
            var linhas = document.querySelectorAll('#tabelaCorpo tr');
            var msgSemResultados = document.getElementById('msgSemResultados');
            var encontrouAlgum = false;

            linhas.forEach(function(linha) {
                var detalhes = linha.cells[1].textContent.toLowerCase();
                var vendedor = linha.cells[2].textContent.toLowerCase();

                if (detalhes.includes(valorPesquisa) || vendedor.includes(valorPesquisa)) {
                    linha.style.display = '';
                    encontrouAlgum = true;
                } else {
                    linha.style.display = 'none';
                }
            });

            if (!encontrouAlgum) {
                msgSemResultados.style.display = 'block';
            } else {
                msgSemResultados.style.display = 'none';
            }
        });
    </script>
}